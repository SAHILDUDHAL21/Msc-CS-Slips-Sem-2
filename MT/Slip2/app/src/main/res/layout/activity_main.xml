<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="32dp"
    android:background="#EEEEEE"
    android:gravity="center_horizontal">

    <EditText
        android:id="@+id/edit_text"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@null"
        android:gravity="bottom|start"
        android:focusable="false"
        android:clickable="false"
        android:cursorVisible="false"
        android:inputType="none"
        android:minHeight="48dp"
        android:textColor="#009688"
        android:textSize="24sp"
        android:paddingStart="8dp"
        android:paddingEnd="8dp"
        android:autofillHints="none" />

    <View
        android:layout_width="match_parent"
        android:layout_height="2dp"
        android:background="#009688"
        android:layout_marginBottom="64dp"/>

    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal">

        <GridLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:columnCount="3">

            <Button android:id="@+id/btn1" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="1" android:layout_margin="4dp" android:backgroundTint="#D3D3D3" android:textColor="#000000" android:minWidth="64dp" />
            <Button android:id="@+id/btn2" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="2" android:layout_margin="4dp" android:backgroundTint="#D3D3D3" android:textColor="#000000" android:minWidth="64dp" />
            <Button android:id="@+id/btn3" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="3" android:layout_margin="4dp" android:backgroundTint="#D3D3D3" android:textColor="#000000" android:minWidth="64dp" />

            <Button android:id="@+id/btn4" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="4" android:layout_margin="4dp" android:backgroundTint="#D3D3D3" android:textColor="#000000" android:minWidth="64dp" />
            <Button android:id="@+id/btn5" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="5" android:layout_margin="4dp" android:backgroundTint="#D3D3D3" android:textColor="#000000" android:minWidth="64dp" />
            <Button android:id="@+id/btn6" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="6" android:layout_margin="4dp" android:backgroundTint="#D3D3D3" android:textColor="#000000" android:minWidth="64dp" />

            <Button android:id="@+id/btn7" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="7" android:layout_margin="4dp" android:backgroundTint="#D3D3D3" android:textColor="#000000" android:minWidth="64dp" />
            <Button android:id="@+id/btn8" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="8" android:layout_margin="4dp" android:backgroundTint="#D3D3D3" android:textColor="#000000" android:minWidth="64dp" />
            <Button android:id="@+id/btn9" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="9" android:layout_margin="4dp" android:backgroundTint="#D3D3D3" android:textColor="#000000" android:minWidth="64dp" />

            <Button android:id="@+id/btnDot" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="." android:layout_margin="4dp" android:backgroundTint="#D3D3D3" android:textColor="#000000" android:minWidth="64dp" />
            <Button android:id="@+id/btn0" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="0" android:layout_margin="4dp" android:backgroundTint="#D3D3D3" android:textColor="#000000" android:minWidth="64dp" />
            <Button android:id="@+id/btnClear" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="C" android:layout_margin="4dp" android:backgroundTint="#D3D3D3" android:textColor="#000000" android:minWidth="64dp" />

        </GridLayout>

        <View
            android:layout_width="32dp"
            android:layout_height="match_parent" />

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <Button android:id="@+id/btnAdd" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="+" android:layout_margin="4dp" android:backgroundTint="#D3D3D3" android:textColor="#000000" android:minWidth="80dp" />
            <Button android:id="@+id/btnSub" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="-" android:layout_margin="4dp" android:backgroundTint="#D3D3D3" android:textColor="#000000" android:minWidth="80dp" />
            <Button android:id="@+id/btnMul" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="*" android:layout_margin="4dp" android:backgroundTint="#D3D3D3" android:textColor="#000000" android:minWidth="80dp" />
            <Button android:id="@+id/btnDiv" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="/" android:layout_margin="4dp" android:backgroundTint="#D3D3D3" android:textColor="#000000" android:minWidth="80dp" />

        </LinearLayout>
    </LinearLayout>

    <Button
        android:id="@+id/btnEqual"
        android:layout_width="280dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="32dp"
        android:text="="
        android:backgroundTint="#D3D3D3"
        android:textColor="#000000" />

</LinearLayout>
